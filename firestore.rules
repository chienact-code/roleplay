rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: chỉ đọc/ghi profile của chính mình
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Courses: instructor quản lý, student chỉ đọc
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "instructor";
    }

    // Groups & Scenarios dưới courses
    match /courses/{courseId}/{sub=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "instructor";
    }

    // Sessions: instructor tạo, student đọc (theo code)
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "instructor";
    }

    // Messages & Runs dưới sessions: ai cũng được ghi (student chat)
    match /sessions/{sessionId}/{sub=**} {
      allow read, write: if request.auth != null;
    }
  }
}
